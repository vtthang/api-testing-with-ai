    {
      "name": "FLOW Full CRUD",
      "item": [
        {
          "name": "[FLOW] Full CRUD - Step 1: Create new object",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[CRUD Step 1] Status 200 — object created', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 1] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 1] id is auto-generated', function () {",
                  "    pm.expect(pm.response.json().id).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('[CRUD Step 1] createdAt is present', function () {",
                  "    pm.expect(pm.response.json().createdAt).to.be.a('number');",
                  "});",
                  "",
                  "// Persist created ID for all subsequent CRUD steps",
                  "pm.collectionVariables.set('crudObjectId', pm.response.json().id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Samsung Galaxy S23 Ultra\",\n  \"data\": {\n    \"color\": \"Phantom Black\",\n    \"storage\": \"256 GB\",\n    \"price\": 1199.99,\n    \"year\": 2023\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/objects",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "objects"
              ]
            }
          },
          "response": []
        },
        {
          "name": "[FLOW] Full CRUD - Step 2: Read created object",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[CRUD Step 2] Status 200 — object readable', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 2] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 2] Returned object matches created ID', function () {",
                  "    pm.expect(pm.response.json().id).to.equal(pm.collectionVariables.get('crudObjectId'));",
                  "});",
                  "",
                  "pm.test('[CRUD Step 2] Name matches creation payload', function () {",
                  "    pm.expect(pm.response.json().name).to.equal('Samsung Galaxy S23 Ultra');",
                  "});",
                  "",
                  "pm.test('[CRUD Step 2] data fields match creation payload', function () {",
                  "    const data = pm.response.json().data;",
                  "    pm.expect(data.color).to.equal('Phantom Black');",
                  "    pm.expect(data.storage).to.equal('256 GB');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/objects/{{crudObjectId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "objects",
                "{{crudObjectId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "[FLOW] Full CRUD - Step 3: Full replace with PUT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[CRUD Step 3] Status 200 — PUT succeeded', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 3] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 3] Name is fully replaced', function () {",
                  "    pm.expect(pm.response.json().name).to.equal('Samsung Galaxy S23 Ultra — Replaced');",
                  "});",
                  "pm.test('[CRUD Step 3] color is fully replaced', function () {",
                  "    pm.expect(pm.response.json().data.color).to.equal('Cream');",
                  "});",
                  "pm.test('[CRUD Step 3] storage is fully replaced', function () {",
                  "    pm.expect(pm.response.json().data.storage).to.equal('512 GB');",
                  "",
                  "});",
                  "pm.test('[CRUD Step 3] data.replaced flag is present (new field)', function () {",
                  "    pm.expect(pm.response.json().data.replaced).to.equal(true);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 3] updatedAt is present after PUT', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('updatedAt');",
                  "});",
                  "",
                  "pm.test('[CRUD Step 3] ID unchanged after PUT', function () {",
                  "    pm.expect(pm.response.json().id).to.equal(pm.collectionVariables.get('crudObjectId'));",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Samsung Galaxy S23 Ultra — Replaced\",\n  \"data\": {\n    \"color\": \"Cream\",\n    \"storage\": \"512 GB\",\n    \"price\": 1299.99,\n    \"year\": 2023,\n    \"replaced\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/objects/{{crudObjectId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "objects",
                "{{crudObjectId}}"
              ]
            }
          },
          "response": []
        },
