    {
      "name": "FLOW List and Retrieve",
      "item": [
        {
          "name": "[FLOW] List and Retrieve - Step 1: List all objects and extract random ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[L&R Step 1] Status 200 — list returned', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[L&R Step 1] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[L&R Step 1] Response is a non-empty array', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array').with.length.greaterThan(0);",
                  "});",
                  "",
                  "// Extract a random ID and store the first three IDs for filtering",
                  "const objects = pm.response.json();",
                  "const idx = Math.floor(Math.random() * objects.length);",
                  "pm.collectionVariables.set('randomObjectId', objects[idx].id);",
                  "pm.collectionVariables.set('filterIdA', objects[0].id);",
                  "pm.collectionVariables.set('filterIdB', objects[1 < objects.length ? 1 : 0].id);",
                  "pm.collectionVariables.set('filterIdC', objects[2 < objects.length ? 2 : 0].id);",
                  "",
                  "pm.test('[L&R Step 1] Random ID extracted and stored', function () {",
                  "    pm.expect(pm.collectionVariables.get('randomObjectId')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/objects",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "objects"
              ]
            }
          },
          "response": []
        },
        {
          "name": "[FLOW] List and Retrieve - Step 2: Get object by extracted random ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[L&R Step 2] Status 200 — random object found', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[L&R Step 2] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[L&R Step 2] Returned id matches the stored random ID', function () {",
                  "    const expectedId = pm.collectionVariables.get('randomObjectId');",
                  "    pm.expect(pm.response.json().id).to.equal(expectedId);",
                  "});",
                  "",
                  "pm.test('[L&R Step 2] Object schema valid: id, name, data present', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('data');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/objects/{{randomObjectId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "objects",
                "{{randomObjectId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "[FLOW] List and Retrieve - Step 3: Filter objects by three extracted IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[L&R Step 3] Status 200 — filtered list returned', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[L&R Step 3] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[L&R Step 3] All three requested IDs are present in the result', function () {",
                  "    const ids = pm.response.json().map(function (o) { return o.id; });",
                  "    const a = pm.collectionVariables.get('filterIdA');",
                  "    const b = pm.collectionVariables.get('filterIdB');",
                  "    const c = pm.collectionVariables.get('filterIdC');",
                  "    // If a == b == c (single unique ID), result length is 1",
                  "    const uniqueExpected = [...new Set([a, b, c])];",
                  "    uniqueExpected.forEach(function (id) {",
                  "        pm.expect(ids).to.include(id);",
                  "    });",
                  "});",
                  "",
                  "pm.test('[L&R Step 3] Result contains only requested IDs', function () {",
                  "    const allowed = [",
                  "        pm.collectionVariables.get('filterIdA'),",
                  "        pm.collectionVariables.get('filterIdB'),",
                  "        pm.collectionVariables.get('filterIdC')",
                  "    ];",
                  "    pm.response.json().forEach(function (obj) {",
                  "        pm.expect(allowed).to.include(obj.id);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/objects?id={{filterIdA}}&id={{filterIdB}}&id={{filterIdC}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "objects"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{filterIdA}}"
                },
                {
                  "key": "id",
                  "value": "{{filterIdB}}"
                },
                {
                  "key": "id",
                  "value": "{{filterIdC}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
