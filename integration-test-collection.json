                  "});",
                  "",
                  "pm.test('[CRUD Step 4] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 4] Name is updated by PATCH', function () {",
                  "    pm.expect(pm.response.json().name).to.equal('Samsung Galaxy S23 Ultra — Patched');",
                  "});",
                  "",
                  "pm.test('[CRUD Step 4] Patched color in data', function () {",
                  "    pm.expect(pm.response.json().data.color).to.equal('Green');",
                  "});",
                  "",
                  "pm.test('[CRUD Step 4] updatedAt is present after PATCH', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('updatedAt');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
