        {
          "name": "[FLOW] Full CRUD - Step 5: Delete object",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[CRUD Step 5] Status 200 — object deleted', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 5] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 5] Deletion message is present', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('message');",
                  "});",
                  "",
                  "pm.test('[CRUD Step 5] Message references the deleted ID', function () {",
                  "    const id = pm.collectionVariables.get('crudObjectId');",
                  "    pm.expect(pm.response.json().message).to.include(id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
