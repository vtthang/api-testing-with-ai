        {
          "name": "[FLOW] Full CRUD - Step 6: Verify object is gone (GET returns 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[CRUD Step 6] Status 404 — deleted object is gone', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 6] Response time under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[CRUD Step 6] Error body confirms object not found', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('error');",
                  "});",
                  "",
                  "// Clean up flow variable",
                  "pm.collectionVariables.set('crudObjectId', '');"
